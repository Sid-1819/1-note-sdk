{
  "name": "@1note/sdk",
  "version": "0.0.2",
  "description": "TypeScript client for the 1Note (secureShare) notes HTTP API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "bin": {
    "1note": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "cli": "node ./dist/cli.js",
    "prepublishOnly": "pnpm run build",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
